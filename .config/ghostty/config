theme = catppuccin-macchiato.conf
background-opacity = 0.8
background-blur = true


macos-titlebar-style = transparent

font-size = 16
font-thicken = true
font-family = JetBrains Mono

copy-on-select = clipboard
macos-option-as-alt = left

shell-integration = zsh

keybind = ctrl+n=new_window

keybind = alt+l=next_tab
keybind = alt+h=previous_tab

keybind = ctrl+g>left=goto_split:left
keybind = ctrl+g>down=goto_split:bottom
keybind = ctrl+g>up=goto_split:top
keybind = ctrl+g>right=goto_split:right

keybind = ctrl+g>h=new_split:left
keybind = ctrl+g>j=new_split:down
keybind = ctrl+g>k=new_split:up
keybind = ctrl+g>l=new_split:right

keybind = ctrl+g>f=toggle_split_zoom

window-save-state = always
